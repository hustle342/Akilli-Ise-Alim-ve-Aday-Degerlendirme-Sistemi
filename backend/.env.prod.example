# backend/.env.prod — Üretim Ortamı Değişkenleri
# Bu dosyayı doldurup asla Git'e commit ETMEYİN.
# .gitignore içinde backend/.env.prod satırının bulunduğundan emin olun.

# Veritabanı (docker-compose.prod.yml ile uyumlu)
DATABASE_URL=postgresql+psycopg://postgres:GUCLU_SIFRE_YAZ@db:5432/recruitment
POSTGRES_PASSWORD=GUCLU_SIFRE_YAZ

# Uygulama gizli anahtarı (en az 32 karakter, rastgele üretin)
SECRET_KEY=buraya-cok-uzun-ve-rastgele-bir-deger-yazin

# Token süreleri (saniye)
ACCESS_TOKEN_MAX_AGE_SECONDS=3600
REFRESH_TOKEN_MAX_AGE_SECONDS=604800

# Admin kayıt kodu (güçlü bir değer seçin)
ADMIN_BOOTSTRAP_CODE=buraya-guclu-bir-bootstrap-kodu-yazin

# CV dosya depolama dizini (container içi yol)
CV_STORAGE_DIR=/app/storage/cvs

# Gunicorn worker sayısı (CPU çekirdeği × 2 + 1 önerilir)
WORKERS=4
THREADS=2
TIMEOUT=120
